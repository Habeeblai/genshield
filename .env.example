# -------------------------------------------------------
# SERVER-SIDE (add to Vercel Environment Variables)
# -------------------------------------------------------
# Get this from Google AI Studio: https://aistudio.google.com
GEMINI_API_KEY=

# -------------------------------------------------------
# CLIENT-SIDE (add to Vercel Environment Variables)
# These MUST be set before building — Vite inlines them
# -------------------------------------------------------

# The RPC endpoint for GenLayer.
# For Studionet (recommended): https://studio.genlayer.com/api
# For Testnet Asimov:          https://rpc.testnet.genlayer.com
VITE_GENLAYER_RPC_URL=https://studio.genlayer.com/api

# The address of your deployed ScamDetector contract.
# Deploy via GenLayer Studio and paste the address here.
VITE_CONTRACT_ADDRESS=
